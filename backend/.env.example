# Backend Environment Variables

# Server
NODE_ENV=development
PORT=3001
HOST=localhost

# ⚠️ SOLO PARA DESARROLLO LOCAL EN REDES CORPORATIVAS
# Descomenta la siguiente línea si tienes errores de "self-signed certificate in certificate chain"
# Esto puede ocurrir en redes corporativas con proxies SSL
# ⚠️ NUNCA activar en producción - El código bloqueará el inicio si NODE_ENV=production
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=plataforma_contable
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600

# Supabase (when needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Google Sheets
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY_PATH=./credentials/google-service-account.json

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
