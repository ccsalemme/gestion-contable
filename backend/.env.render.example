# Script para configurar variables de entorno en Render
# NO ejecutar localmente - copiar estos valores en el dashboard de Render

# =============================================================================
# VARIABLES DE ENTORNO REQUERIDAS PARA RENDER (Backend)
# =============================================================================

# 1. Ambiente
NODE_ENV=production

# 2. Puerto (Render lo asigna automáticamente, pero puedes especificar)
# PORT=3001

# 3. JWT Secret (GENERAR UNO NUEVO - ejecuta el comando de abajo)
# Ejecutar en terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_SECRET_GENERADO_DE_64_BYTES
JWT_EXPIRATION=3600

# 4. Database (PostgreSQL en Render)
# Render te da esta URL automáticamente cuando creas un PostgreSQL
DATABASE_URL=${postgresql://usuario:password@host:puerto/database}

# 5. CORS - Especificar el dominio de tu frontend
# Para GitHub Pages: https://tu-usuario.github.io
# Para múltiples orígenes: https://app1.com,https://app2.com
CORS_ORIGIN=https://TU-USUARIO.github.io

# 6. Google Service Account Credentials
# EN LUGAR DE ARCHIVO .json, usar la credencial completa como JSON string:
# Copia TODO el contenido de google-service-account.json y pégalo como una sola línea
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# 7. Logging
LOG_LEVEL=info

# 8. Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CÓMO CONFIGURAR EN RENDER
# =============================================================================

# 1. Ve a tu servicio en Render Dashboard
# 2. Click en "Environment" en el menú lateral
# 3. Click en "Add Environment Variable"
# 4. Copia cada variable de arriba (nombre y valor)
# 5. Para secrets sensibles, marca "Secret" para que queden ocultos

# =============================================================================
# DESPUÉS DE CONFIGURAR
# =============================================================================

# Render automáticamente re-desplegará tu aplicación con las nuevas variables
# Verifica los logs para confirmar que todo está funcionando
