# Configuración para GitHub Pages
# Este archivo debe estar en .github/workflows/ o usar GitHub Secrets

# =============================================================================
# VARIABLES DE ENTORNO PARA FRONTEND (GitHub Pages)
# =============================================================================

# URL de tu backend en Render
VITE_API_BASE_URL=https://tu-backend-name.onrender.com/api

# Información de la aplicación
VITE_APP_NAME=Plataforma de Gestión Contable
VITE_APP_VERSION=1.0.0

# Sheet ID por defecto (si aplica)
VITE_DEFAULT_SHEET_ID=1jzGjT49CVcsaNau6okiZHlLt58cKlnB8qxVg2-jrJyE

# =============================================================================
# CONFIGURAR EN GITHUB
# =============================================================================

# Opción 1: GitHub Secrets (RECOMENDADO)
# 1. Ve a tu repositorio en GitHub
# 2. Settings > Secrets and variables > Actions
# 3. Click "New repository secret"
# 4. Agrega cada variable:
#    - Name: VITE_API_BASE_URL
#    - Value: https://tu-backend.onrender.com/api

# Opción 2: GitHub Pages Environment Variables
# Si usas Vite + GitHub Actions para build:
# Crea un archivo .github/workflows/deploy.yml

